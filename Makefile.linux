CC ?= gcc
CFLAGS ?= -Wall -Wextra -std=c11 -g -D_POSIX_C_SOURCE=200809L
OUTDIR ?= build_out

.PHONY: test clean

$(OUTDIR):
	mkdir -p $(OUTDIR)

$(OUTDIR)/unit_eth: tests/unit_eth.c src/eth.c include/dephy_eth/eth.h | $(OUTDIR)
	$(CC) $(CFLAGS) -Iinclude tests/unit_eth.c src/eth.c -o $@

test: $(OUTDIR)/unit_eth
	$<

clean:
	rm -rf $(OUTDIR)
